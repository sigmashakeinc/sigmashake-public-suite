{
  "version": 1,
  "bootstrap": [
    {
      "id": "install",
      "name": "Install component dependencies",
      "commands": [
        { "service": "mmo", "cwd": "services/mmo", "cmd": "bun install --frozen-lockfile" },
        { "service": "abyss", "cwd": "services/abyss", "cmd": "bun install --frozen-lockfile" },
        { "service": "vcs", "cwd": "services/vcs", "cmd": "bun install --frozen-lockfile" }
      ]
    }
  ],
  "preflight": [
    {
      "id": "suite-syntax",
      "name": "Suite automation syntax",
      "commands": [
        { "service": "suite", "cwd": ".", "cmd": "node --check scripts/run-gates.mjs" },
        { "service": "suite", "cwd": ".", "cmd": "node --check scripts/review-policy.mjs" },
        { "service": "suite", "cwd": ".", "cmd": "bash -lc 'for f in scripts/*.sh; do bash -n \"$f\"; done'" }
      ]
    },
    {
      "id": "typecheck",
      "name": "Service typechecks",
      "commands": [
        { "service": "mmo", "cwd": "services/mmo", "cmd": "bun run typecheck" },
        { "service": "abyss", "cwd": "services/abyss", "cmd": "bun run typecheck" },
        { "service": "vcs", "cwd": "services/vcs", "cmd": "bun run typecheck" }
      ]
    },
    {
      "id": "lint",
      "name": "Service lint",
      "commands": [
        { "service": "mmo", "cwd": "services/mmo", "cmd": "bunx @biomejs/biome@2.4.15 check ." },
        { "service": "abyss", "cwd": "services/abyss", "cmd": "bunx @biomejs/biome@2.4.15 check ." },
        { "service": "vcs", "cwd": "services/vcs", "cmd": "bunx @biomejs/biome@2.4.15 check ." }
      ]
    }
  ],
  "tests": [
    {
      "id": "unit",
      "name": "Unit tests",
      "commands": [
        { "service": "mmo", "cwd": "services/mmo", "cmd": "bun run test:unit" },
        { "service": "abyss", "cwd": "services/abyss", "cmd": "bun run test" },
        { "service": "vcs", "cwd": "services/vcs", "cmd": "bun run test" }
      ]
    },
    {
      "id": "api",
      "name": "API tests",
      "commands": [
        { "service": "mmo", "cwd": "services/mmo", "cmd": "bun run test:api" },
        { "service": "vcs", "cwd": "services/vcs", "cmd": "bun run test:api" }
      ]
    },
    {
